# ==========================================
# Email Verification System - Backend
# ==========================================

# Database
DATABASE_URL=mysql+pymysql://<DB_USERNAME>:<DB_PASSWORD>@<DB_HOST>:3306/<DB_NAME>
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DEBUG_SQL=false

# Disposable email checker (configured in config.py)
DISPOSABLE_CACHE_TTL=86400
DISPOSABLE_SOURCES=["https://raw.githubusercontent.com/disposable-email-domains/disposable-email-domains/master/disposable_email_blocklist.conf","https://raw.githubusercontent.com/FGRibreau/mailchecker/master/list.txt"]

# SMTP
SMTP_TIMEOUT=3
SMTP_RETRIES=2
SMTP_MAX_WORKERS=20
SMTP_MAX_MX_TO_TRY=2
SMTP_SENDER_EMAIL=verify@emailchecker.com
SMTP_HELO_DOMAIN=emailchecker.com

# AWS
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
AWS_REGION=ap-south-1
S3_BUCKET_NAME=email-verifier-uploads

# Application
SECRET_KEY=<YOUR_SECRET_KEY>
DEBUG=false
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS='["http://localhost:3000"]'